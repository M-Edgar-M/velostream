# Database
DATABASE_URL="postgresql://user:password@postgres:5432/velostream"

# Redis
REDIS_URL="redis://redis:6379"

# MinIO (S3 Compatible)
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="velostream-uploads"

# The "Dual-URL" Fix
# Internal endpoint for container-to-container communication
MINIO_ENDPOINT="http://minio:9000"
# External URL for presigned URLs (browser to host port mapping)
MINIO_PUBLIC_URL="http://localhost:9000"
